<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="240dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="141dp"
            android:layout_height="100dp"
            android:gravity="center"
            android:paddingBottom="0dp"
            android:paddingTop="1dp"
            android:text="
            BreathEZ"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="16dp"
            android:text="CPAP Controller"
            android:textColor="#8B949E"
            android:textSize="13sp" />

        <!-- STATUS -->
        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="#B71C1C"
            android:gravity="center"
            android:padding="10dp"
            android:text="Not Connected"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <!-- CONNECT -->
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="18dp"
            android:backgroundTint="#1F6FEB"
            android:text="Connect Device"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <!-- LIVE DATA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="LIVE DATA"
                android:textColor="#58A6FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="Mode: —"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="8dp"
                android:background="#30363D" />

            <!-- DATA TEXT (SAFE SIZE, NO WRAPPING ISSUE) -->

            <TextView
                android:id="@+id/tvBPM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BPM: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAvgBreath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Avg Breath Interval: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMaxBreath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Max Breath Interval: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMinBreath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Min Breath Interval: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPressure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pressure: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSpeedLVL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speed Level: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPWM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PWM: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvHumid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Humidifier: —"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

<!--            <TextView-->
<!--                android:id="@+id/tvPressure"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Pressure: —"-->
<!--                android:textColor="#C9D1D9"-->
<!--                android:textSize="14sp" />-->

<!--            <TextView-->
<!--                android:id="@+id/tvSpeedLVL"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Speed Level: —"-->
<!--                android:textColor="#C9D1D9"-->
<!--                android:textSize="14sp" />-->

<!--            <TextView-->
<!--                android:id="@+id/tvPWM"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="PWM: —"-->
<!--                android:textColor="#C9D1D9"-->
<!--                android:textSize="14sp" />-->

<!--            <TextView-->
<!--                android:id="@+id/tvHumid"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Humidifier: —"-->
<!--                android:textColor="#C9D1D9"-->
<!--                android:textSize="14sp" />-->

        </LinearLayout>

        <!-- CONTROL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#161B22"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="10dp"
                android:text="CONTROL"
                android:textColor="#58A6FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- SAME ROW (UNCHANGED STRUCTURE) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAuto"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#238636"
                    android:text="AUTO"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnManual"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1.1"
                    android:backgroundTint="#DA3633"
                    android:text="MANUAL"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:backgroundTint="#6E7681"
                    android:text="RESET"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- MANUAL -->
            <LinearLayout
                android:id="@+id/layoutManualControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp"
                android:visibility="gone">

                <NumberPicker
                    android:id="@+id/numberPicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center" />

                <Button
                    android:id="@+id/btnSetSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#DA3633"
                    android:text="Apply Speed"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>

        <!-- LOG -->
        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#0D1117"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Waiting..."
                android:textColor="#8B949E"
                android:textSize="12sp" />
        </ScrollView>

    </LinearLayout>
</ScrollView>